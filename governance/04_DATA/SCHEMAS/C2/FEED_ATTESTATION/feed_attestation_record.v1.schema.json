{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "C2_FEED_ATTESTATION_RECORD_V1_SCHEMA",
  "title": "C2 Feed Attestation Record v1 (Hash Chain + Monotonic Sequence)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "artifact_id",
    "day_utc",
    "produced_utc",
    "producer",
    "sequence_id",
    "target_relpath",
    "target_sha256",
    "source_snapshot_utc",
    "upstream_source_hash",
    "previous_attestation_sha256",
    "attestation_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_FEED_ATTESTATION_RECORD_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "artifact_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "minLength": 1 },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "git_sha", "module"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },

    "sequence_id": { "type": "integer", "minimum": 1 },

    "target_relpath": { "type": "string", "minLength": 1, "maxLength": 1024 },
    "target_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },

    "source_snapshot_utc": { "type": "string", "minLength": 1 },
    "upstream_source_hash": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },

    "previous_attestation_sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },

    "attestation_sha256": {
      "type": "string",
      "description": "sha256 of canonical JSON for this document, excluding this field",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
