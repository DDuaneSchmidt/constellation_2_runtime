{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "C2_AUTHORIZATION_V1",
  "title": "C2 Authorization Artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "produced_utc",
    "day_utc",
    "producer",
    "status",
    "reason_codes",
    "input_manifest",
    "engine_id",
    "intent_id",
    "intent_hash",
    "authorization"
  ],
  "properties": {
    "schema_id": { "const": "C2_AUTHORIZATION_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "produced_utc": { "type": "string", "minLength": 1 },
    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "git_sha", "module"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "git_sha": { "type": "string", "pattern": "^[0-9a-f]{7,40}$" },
        "module": { "type": "string", "minLength": 1 },
        "build": { "type": "object" }
      }
    },

    "status": {
      "type": "string",
      "enum": [
        "AUTHORIZED",
        "REJECTED",
        "FAIL_MISSING_INPUTS",
        "FAIL_CORRUPT_INPUTS",
        "FAIL_SCHEMA_VIOLATION"
      ]
    },

    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },

    "input_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256", "day_utc", "producer"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "intent",
              "exposure_net",
              "capital_authority_allocation",
              "policy_manifest",
              "positions_snapshot",
              "cash_ledger_snapshot",
              "other"
            ]
          },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "day_utc": {
            "anyOf": [
              { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
              { "type": "null" }
            ]
          },
          "producer": { "type": "string", "minLength": 1 }
        }
      }
    },

    "engine_id": { "type": "string", "minLength": 1 },
    "intent_id": { "type": "string", "minLength": 1 },
    "intent_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },

    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision",
        "authorized_quantity",
        "constraints",
        "decision_hash"
      ],
      "properties": {
        "decision": { "type": "string", "enum": ["AUTHORIZED", "REJECTED", "PARTIAL"] },
        "authorized_quantity": { "type": "integer", "minimum": 0 },
        "constraints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "decision_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "sha256 of canonical JSON of authorization decision block (excluding decision_hash), for deterministic linkage."
        }
      }
    }
  }
}
