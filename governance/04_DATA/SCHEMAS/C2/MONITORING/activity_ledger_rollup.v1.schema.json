{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "C2 Activity Ledger Rollup v1 (as-of day)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "produced_utc",
    "asof_day_utc",
    "producer",
    "status",
    "totals",
    "days",
    "input_manifest",
    "reason_codes"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "activity_ledger_rollup" },
    "schema_version": { "type": "string", "const": "v1" },
    "produced_utc": { "type": "string", "minLength": 1 },
    "asof_day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "module": { "type": "string", "minLength": 1 },
        "git_sha": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "type": "string", "enum": ["OK", "FAIL"] },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["intents_total", "submissions_total"],
      "properties": {
        "intents_total": { "type": "integer", "minimum": 0 },
        "submissions_total": { "type": "integer", "minimum": 0 }
      }
    },
    "days": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["day_utc", "intents_total", "submissions_total"],
        "properties": {
          "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "intents_total": { "type": "integer", "minimum": 0 },
          "submissions_total": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "input_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256"],
        "properties": {
          "type": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
        }
      }
    },
    "reason_codes": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
