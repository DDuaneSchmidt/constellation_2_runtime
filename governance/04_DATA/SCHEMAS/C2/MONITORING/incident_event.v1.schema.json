{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c2.monitoring.incident_event.v1",
  "title": "C2 Incident Event v1 (authoritative anomaly/incident record; immutable per incident_id)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "incident_id",
    "day_utc",
    "detected_utc",
    "severity",
    "rule_id",
    "status",
    "action_taken",
    "recommended_operator_action",
    "artifact_refs",
    "input_manifest",
    "producer",
    "incident_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_INCIDENT_EVENT_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "incident_id": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Deterministic incident id, typically sha256(canonical_json_bytes of incident core fields)."
    },

    "day_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },

    "detected_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },

    "severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },

    "rule_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 120
    },

    "status": {
      "type": "string",
      "enum": ["OPEN", "ACKNOWLEDGED", "RESOLVED"]
    },

    "action_taken": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system_action", "details"],
      "properties": {
        "system_action": {
          "type": "string",
          "enum": ["NONE", "WARN_ONLY", "KILL_SWITCH_ACTIVATED", "SUBMISSION_BLOCKED"]
        },
        "details": { "type": "string", "minLength": 1, "maxLength": 800 }
      }
    },

    "recommended_operator_action": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },

    "artifact_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "type"],
        "properties": {
          "path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "type": { "type": "string", "minLength": 1, "maxLength": 80 }
        }
      }
    },

    "input_manifest": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "maxLength": 80 },
          "path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 120 },
        "module": { "type": "string", "minLength": 1, "maxLength": 220 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 }
      }
    },

    "incident_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Self-hash of canonical JSON bytes with incident_sha256 field set to null/empty during hashing, then populated."
    }
  }
}
