{
  "$id": "https://constellation.local/schemas/eod_slo_sentinel.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constellation 2.0 — EOD SLO Sentinel (V1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "status",
    "state",
    "details"
  ],
  "properties": {
    "schema_id": { "const": "eod_slo_sentinel" },
    "schema_version": { "const": 1 },

    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "minLength": 10, "maxLength": 40 },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 },
        "git_sha": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" }
      }
    },

    "status": { "type": "string", "enum": ["OK", "FAIL"] },

    "state": {
      "type": "string",
      "enum": ["OK", "CERT_MISSING", "CERT_FAIL", "LATE"]
    },

    "details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_day_utc", "deadline_utc", "certificate_path", "certificate_present", "certificate_status"],
      "properties": {
        "expected_day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "deadline_utc": { "type": "string", "minLength": 10, "maxLength": 40 },
        "certificate_path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "certificate_present": { "type": "boolean" },
        "certificate_status": { "type": "string", "minLength": 1, "maxLength": 32 },
        "notes": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    }
  }
}
