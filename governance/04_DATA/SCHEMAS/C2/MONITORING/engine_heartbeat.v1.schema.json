{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c2.monitoring.engine_heartbeat.v1",
  "title": "C2 Engine Heartbeat v1 (authoritative liveness artifact; deterministic; fail-closed consumer posture)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "engine_id",
    "status",
    "reason_codes",
    "last_run_utc",
    "produced_utc",
    "producer",
    "input_manifest",
    "heartbeat_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_ENGINE_HEARTBEAT_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "day_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },

    "engine_id": {
      "type": "string",
      "minLength": 3,
      "maxLength": 128
    },

    "status": {
      "type": "string",
      "enum": ["OK", "WARN", "FAIL"]
    },

    "reason_codes": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 160 },
      "minItems": 1
    },

    "last_run_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },

    "last_signal_utc": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },

    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_period_seconds", "stale_after_seconds"],
      "properties": {
        "expected_period_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 },
        "stale_after_seconds": { "type": "integer", "minimum": 1, "maximum": 604800 }
      }
    },

    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprints"],
      "properties": {
        "fingerprints": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "path", "sha256", "present"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 80 },
              "path": { "type": "string", "minLength": 1, "maxLength": 512 },
              "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "present": { "type": "boolean" }
            }
          }
        }
      }
    },

    "input_manifest": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "maxLength": 80 },
          "path": { "type": "string", "minLength": 1, "maxLength": 512 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },

    "produced_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 120 },
        "module": { "type": "string", "minLength": 1, "maxLength": 220 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 }
      }
    },

    "heartbeat_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "Self-hash of canonical JSON bytes with heartbeat_sha256 field set to null/empty during hashing, then populated."
    }
  }
}
