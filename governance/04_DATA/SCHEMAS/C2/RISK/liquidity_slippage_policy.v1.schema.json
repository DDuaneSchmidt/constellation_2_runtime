{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c2.risk.liquidity_slippage_policy.v1",
  "title": "C2 Liquidity + Slippage Policy v1 (Governance Registry)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "status",
    "created_utc",
    "owner",
    "notes",
    "defaults",
    "symbol_overrides",
    "reason_codes"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_LIQUIDITY_SLIPPAGE_POLICY_V1" },
    "schema_version": { "type": "integer", "const": 1 },
    "status": { "type": "string", "enum": ["ACTIVE", "DRAFT", "DEPRECATED"] },
    "created_utc": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1, "maxLength": 128 },
    "notes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 512 } },

    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lookback_days",
        "min_history_days",
        "min_adv_shares",
        "max_participation_pct_adv",
        "max_est_slippage_bps",
        "base_slippage_bps",
        "slippage_bps_per_1pct_adv",
        "max_notional_per_symbol_usd",
        "max_orders_per_symbol_per_day",
        "require_regime_snapshot_v2",
        "non_normal_regime_caps_multiplier",
        "allow_missing_symbols",
        "allow_zero_intents_pass"
      ],
      "properties": {
        "lookback_days": { "type": "integer", "minimum": 1, "maximum": 252 },
        "min_history_days": { "type": "integer", "minimum": 1, "maximum": 252 },
        "min_adv_shares": { "type": "integer", "minimum": 0, "maximum": 2000000000 },

        "max_participation_pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
        "max_est_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },

        "base_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
        "slippage_bps_per_1pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },

        "max_notional_per_symbol_usd": { "type": "string", "pattern": "^[0-9]+$" },
        "max_orders_per_symbol_per_day": { "type": "integer", "minimum": 1, "maximum": 1000 },

        "require_regime_snapshot_v2": { "type": "boolean" },
        "non_normal_regime_caps_multiplier": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },

        "allow_missing_symbols": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 32 } },
        "allow_zero_intents_pass": { "type": "boolean" }
      }
    },

    "symbol_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["symbol", "overrides"],
        "properties": {
          "symbol": { "type": "string", "minLength": 1, "maxLength": 32 },
          "overrides": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "lookback_days": { "type": "integer", "minimum": 1, "maximum": 252 },
              "min_history_days": { "type": "integer", "minimum": 1, "maximum": 252 },
              "min_adv_shares": { "type": "integer", "minimum": 0, "maximum": 2000000000 },
              "max_participation_pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
              "max_est_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
              "base_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
              "slippage_bps_per_1pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
              "max_notional_per_symbol_usd": { "type": "string", "pattern": "^[0-9]+$" },
              "max_orders_per_symbol_per_day": { "type": "integer", "minimum": 1, "maximum": 1000 }
            }
          }
        }
      }
    },

    "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } }
  }
}
