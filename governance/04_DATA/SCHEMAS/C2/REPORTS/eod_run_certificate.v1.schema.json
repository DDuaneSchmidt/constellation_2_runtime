{
  "$id": "https://constellation.local/schemas/eod_run_certificate.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constellation 2.0 — EOD Run Certificate (V1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "status",
    "run",
    "artifacts"
  ],
  "properties": {
    "schema_id": { "const": "eod_run_certificate" },
    "schema_version": { "const": 1 },

    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "minLength": 10, "maxLength": 40 },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 },
        "git_sha": { "type": "string", "pattern": "^[a-f0-9]{7,64}$" }
      }
    },

    "status": { "type": "string", "enum": ["PASS", "FAIL"] },

    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "started_utc", "ended_utc", "seed"],
      "properties": {
        "exit_code": { "type": "integer", "minimum": 0, "maximum": 255 },
        "started_utc": { "type": "string", "minLength": 10, "maxLength": 40 },
        "ended_utc": { "type": "string", "minLength": 10, "maxLength": 40 },
        "seed": { "type": "string", "minLength": 1, "maxLength": 512 },
        "error_summary": { "type": "string", "minLength": 0, "maxLength": 4096 }
      }
    },

    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_outputs", "observed_outputs", "missing_outputs"],
      "properties": {
        "expected_outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
        },
        "observed_outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
        },
        "missing_outputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 2048 }
        }
      }
    }
  }
}
