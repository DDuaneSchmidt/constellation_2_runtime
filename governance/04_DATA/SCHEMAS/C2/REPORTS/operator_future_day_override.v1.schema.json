{
  "$id": "https://constellation.local/schemas/operator_future_day_override.v1.schema.json",
  "title": "Operator Future-Day Override v1 (PAPER-only, explicit, immutable)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "override_day_utc",
    "mode",
    "operator_id",
    "reason",
    "acknowledgments",
    "produced_utc",
    "producer",
    "override_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_OPERATOR_FUTURE_DAY_OVERRIDE_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "override_day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },

    "mode": { "type": "string", "enum": ["PAPER"] },

    "operator_id": { "type": "string", "minLength": 1, "maxLength": 128 },
    "reason": { "type": "string", "minLength": 1, "maxLength": 2048 },

    "acknowledgments": {
      "type": "array",
      "minItems": 2,
      "items": { "type": "string", "minLength": 1, "maxLength": 256 }
    },

    "produced_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "git_sha", "module"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },

    "override_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
