{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "C2_DEPTH_LIQUIDITY_STRESS_V1_SCHEMA",
  "title": "C2 Depth Liquidity Stress v1 (Depth-aware spread + nonlinear impact under stress)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "status",
    "fail_closed",
    "policy",
    "inputs",
    "regime_used",
    "regimes",
    "aggregation",
    "enforcement",
    "violations"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_DEPTH_LIQUIDITY_STRESS_V1" },
    "schema_version": { "type": "integer", "const": 1 },
    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "minLength": 1 },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "repo", "git_sha", "module" ],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "status": { "type": "string", "enum": [ "PASS", "SCALE", "BLOCK_ALL", "MISSING_INPUTS", "FAIL" ] },
    "fail_closed": { "type": "boolean" },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "policy_id", "path", "sha256" ],
      "properties": {
        "policy_id": { "type": "string", "const": "C2_DEPTH_LIQUIDITY_STRESS_POLICY_V1" },
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "intents_root",
        "liquidity_dataset_manifest_path",
        "liquidity_dataset_manifest_sha256"
      ],
      "properties": {
        "intents_root": { "type": "string", "minLength": 1 },
        "liquidity_dataset_manifest_path": { "type": "string", "minLength": 1 },
        "liquidity_dataset_manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "regime_used": { "type": "string", "enum": [ "NORMAL", "VOL_EXPANSION", "LIQ_CONTRACTION" ] },
    "regimes": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "NORMAL", "VOL_EXPANSION", "LIQ_CONTRACTION" ],
      "properties": {
        "NORMAL": {
          "type": "object",
          "additionalProperties": false,
          "required": [ "depth_fraction_of_adv", "depth_removal_pct", "spread_widen_multiplier", "impact_k_bps", "impact_alpha" ],
          "properties": {
            "depth_fraction_of_adv": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "depth_removal_pct": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "spread_widen_multiplier": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_k_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_alpha": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
          }
        },
        "VOL_EXPANSION": {
          "type": "object",
          "additionalProperties": false,
          "required": [ "depth_fraction_of_adv", "depth_removal_pct", "spread_widen_multiplier", "impact_k_bps", "impact_alpha" ],
          "properties": {
            "depth_fraction_of_adv": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "depth_removal_pct": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "spread_widen_multiplier": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_k_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_alpha": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
          }
        },
        "LIQ_CONTRACTION": {
          "type": "object",
          "additionalProperties": false,
          "required": [ "depth_fraction_of_adv", "depth_removal_pct", "spread_widen_multiplier", "impact_k_bps", "impact_alpha" ],
          "properties": {
            "depth_fraction_of_adv": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "depth_removal_pct": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "spread_widen_multiplier": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_k_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "impact_alpha": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
          }
        }
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [ "by_symbol", "portfolio" ],
      "properties": {
        "by_symbol": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [ "intent_notional_dollar", "price_close", "adv_shares", "adv_dollar", "regimes" ],
            "properties": {
              "intent_notional_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
              "price_close": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
              "adv_shares": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
              "adv_dollar": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
              "regimes": {
                "type": "object",
                "additionalProperties": false,
                "required": [ "NORMAL", "VOL_EXPANSION", "LIQ_CONTRACTION" ],
                "properties": {
                  "NORMAL": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [ "depth_dollar_normal", "depth_dollar_stressed", "spread_bps_stressed", "impact_bps", "total_cost_bps", "total_cost_dollar" ],
                    "properties": {
                      "depth_dollar_normal": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "depth_dollar_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "spread_bps_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "impact_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" }
                    }
                  },
                  "VOL_EXPANSION": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [ "depth_dollar_normal", "depth_dollar_stressed", "spread_bps_stressed", "impact_bps", "total_cost_bps", "total_cost_dollar" ],
                    "properties": {
                      "depth_dollar_normal": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "depth_dollar_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "spread_bps_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "impact_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" }
                    }
                  },
                  "LIQ_CONTRACTION": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [ "depth_dollar_normal", "depth_dollar_stressed", "spread_bps_stressed", "impact_bps", "total_cost_bps", "total_cost_dollar" ],
                    "properties": {
                      "depth_dollar_normal": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "depth_dollar_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "spread_bps_stressed": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "impact_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
                      "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" }
                    }
                  }
                }
              }
            }
          }
        },
        "portfolio": {
          "type": "object",
          "additionalProperties": false,
          "required": [ "total_intent_notional_dollar", "regimes", "max_symbol", "max_symbol_cost_bps" ],
          "properties": {
            "total_intent_notional_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
            "max_symbol": { "type": "string", "minLength": 1 },
            "max_symbol_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
            "regimes": {
              "type": "object",
              "additionalProperties": false,
              "required": [ "NORMAL", "VOL_EXPANSION", "LIQ_CONTRACTION" ],
              "properties": {
                "NORMAL": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [ "total_cost_dollar", "portfolio_cost_bps" ],
                  "properties": {
                    "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
                    "portfolio_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
                  }
                },
                "VOL_EXPANSION": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [ "total_cost_dollar", "portfolio_cost_bps" ],
                  "properties": {
                    "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
                    "portfolio_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
                  }
                },
                "LIQ_CONTRACTION": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [ "total_cost_dollar", "portfolio_cost_bps" ],
                  "properties": {
                    "total_cost_dollar": { "type": "string", "pattern": "^-?[0-9]+(\\.[0-9]+)?$" },
                    "portfolio_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "enforcement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "depth_scale_bp",
        "max_depth_portfolio_cost_bps",
        "max_depth_symbol_cost_bps",
        "portfolio_cost_bps_used",
        "max_symbol_cost_bps_used",
        "reason_codes"
      ],
      "properties": {
        "depth_scale_bp": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "max_depth_portfolio_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_depth_symbol_cost_bps": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "portfolio_cost_bps_used": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "max_symbol_cost_bps_used": { "type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$" },
        "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "violations": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
