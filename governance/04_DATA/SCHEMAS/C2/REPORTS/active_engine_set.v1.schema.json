{
  "$id": "C2_REPORTS_ACTIVE_ENGINE_SET_SCHEMA_V1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_engines": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "engine_id": { "type": "string" },
          "runner_path": { "type": "string" },
          "runner_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          }
        },
        "required": ["engine_id", "runner_path", "runner_sha256"],
        "type": "object"
      },
      "type": "array"
    },
    "approved_git_sha": { "type": "string" },
    "canonical_json_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "day_utc": {
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "type": "string"
    },
    "produced_utc": { "type": "string" },
    "producer": {
      "additionalProperties": false,
      "properties": {
        "git_sha": { "type": "string" },
        "module": { "type": "string" },
        "repo": { "type": "string" }
      },
      "required": ["repo", "module", "git_sha"],
      "type": "object"
    },
    "registry_version": { "type": "integer" },
    "schema_id": { "const": "C2_ACTIVE_ENGINE_SET_V1" },
    "schema_version": { "const": 1 }
  },
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "registry_version",
    "approved_git_sha",
    "active_engines",
    "canonical_json_hash"
  ],
  "title": "C2 Active Engine Set v1",
  "type": "object"
}
