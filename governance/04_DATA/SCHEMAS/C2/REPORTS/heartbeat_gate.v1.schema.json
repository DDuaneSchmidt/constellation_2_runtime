{
  "$id": "c2.reports.heartbeat_gate.v1",
  "title": "C2 Heartbeat Gate v1 (Bundle C) — Engine Heartbeat Presence + Freshness",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "status",
    "fail_closed",
    "policy",
    "results",
    "reason_codes",
    "input_manifest",
    "gate_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_HEARTBEAT_GATE_V1" },
    "schema_version": { "type": "integer", "const": 1 },

    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string" },
        "module": { "type": "string" },
        "git_sha": { "type": "string" }
      }
    },

    "status": { "type": "string", "enum": ["PASS", "FAIL"] },
    "fail_closed": { "type": "boolean", "const": true },

    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_period_seconds", "stale_after_seconds", "require_all_active_engines"],
      "properties": {
        "expected_period_seconds": { "type": "integer", "minimum": 60 },
        "stale_after_seconds": { "type": "integer", "minimum": 60 },
        "require_all_active_engines": { "type": "boolean", "const": true }
      }
    },

    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["by_engine", "totals"],
      "properties": {
        "by_engine": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "engine_id",
              "activation_status",
              "heartbeat_present",
              "heartbeat_path",
              "heartbeat_sha256",
              "heartbeat_status",
              "heartbeat_produced_utc",
              "stale",
              "ok",
              "reason_codes"
            ],
            "properties": {
              "engine_id": { "type": "string", "minLength": 1 },
              "activation_status": { "type": "string", "enum": ["ACTIVE", "INACTIVE", "UNKNOWN"] },

              "heartbeat_present": { "type": "boolean" },
              "heartbeat_path": { "type": "string" },
              "heartbeat_sha256": { "type": "string" },
              "heartbeat_status": { "type": ["string", "null"] },
              "heartbeat_produced_utc": { "type": ["string", "null"] },

              "stale": { "type": "boolean" },
              "ok": { "type": "boolean" },

              "reason_codes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["active_engines", "heartbeats_present", "missing", "stale"],
          "properties": {
            "active_engines": { "type": "integer", "minimum": 0 },
            "heartbeats_present": { "type": "integer", "minimum": 0 },
            "missing": { "type": "integer", "minimum": 0 },
            "stale": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "reason_codes": { "type": "array", "items": { "type": "string" } },

    "input_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256"],
        "properties": {
          "type": { "type": "string" },
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        }
      }
    },

    "gate_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
