{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "c2.reports.liquidity_slippage_gate.v1",
  "title": "C2 Liquidity + Slippage Gate v1 (Pre-trade hard gate output)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "day_utc",
    "produced_utc",
    "producer",
    "status",
    "reason_codes",
    "input_manifest",
    "policy",
    "results",
    "gate_sha256"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "liquidity_slippage_gate" },
    "schema_version": { "type": "string", "const": "v1" },

    "day_utc": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "produced_utc": { "type": "string", "minLength": 1 },

    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "module", "git_sha"],
      "properties": {
        "repo": { "type": "string", "minLength": 1, "maxLength": 128 },
        "module": { "type": "string", "minLength": 1, "maxLength": 256 },
        "git_sha": { "type": "string", "minLength": 7, "maxLength": 64 }
      }
    },

    "status": { "type": "string", "enum": ["PASS", "FAIL", "OK"] },

    "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },

    "input_manifest": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "path", "sha256"],
        "properties": {
          "type": { "type": "string", "minLength": 1, "maxLength": 128 },
          "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },

    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "schema_path", "schema_sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "schema_path": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "schema_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },

    "results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["per_intent", "totals"],
      "properties": {
        "per_intent": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "intent_hash",
              "engine_id",
              "symbol",
              "decision",
              "reason_codes",
              "metrics"
            ],
            "properties": {
              "intent_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
              "engine_id": { "type": "string", "minLength": 1, "maxLength": 128 },
              "symbol": { "type": "string", "minLength": 1, "maxLength": 32 },
              "decision": { "type": "string", "enum": ["PASS", "FAIL", "SKIP"] },
              "reason_codes": { "type": "array", "items": { "type": "string", "minLength": 1, "maxLength": 128 } },
              "metrics": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "nav_total_cents",
                  "target_notional_pct",
                  "est_notional_usd",
                  "close",
                  "est_shares",
                  "adv_shares",
                  "adv_dollar",
                  "participation_pct_adv",
                  "est_slippage_bps",
                  "caps"
                ],
                "properties": {
                  "nav_total_cents": { "type": "integer", "minimum": 0 },
                  "target_notional_pct": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
                  "est_notional_usd": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
                  "close": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
                  "est_shares": { "type": "integer", "minimum": 0 },
                  "adv_shares": { "type": "integer", "minimum": 0 },
                  "adv_dollar": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
                  "participation_pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
                  "est_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
                  "caps": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "max_participation_pct_adv",
                      "max_est_slippage_bps",
                      "max_notional_per_symbol_usd"
                    ],
                    "properties": {
                      "max_participation_pct_adv": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{6}$" },
                      "max_est_slippage_bps": { "type": "string", "pattern": "^[0-9]+\\.[0-9]{2}$" },
                      "max_notional_per_symbol_usd": { "type": "string", "pattern": "^[0-9]+$" }
                    }
                  }
                }
              }
            }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["intents_total", "intents_failed", "intents_passed", "intents_skipped"],
          "properties": {
            "intents_total": { "type": "integer", "minimum": 0 },
            "intents_failed": { "type": "integer", "minimum": 0 },
            "intents_passed": { "type": "integer", "minimum": 0 },
            "intents_skipped": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },

    "gate_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
