{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "execution_evidence_no_execution_event.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "produced_utc",
    "day_utc",
    "submission_id",
    "reason_code",
    "reason_detail",
    "authoritative",
    "canonical_json_hash"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_EXECUTION_EVIDENCE_NO_EXECUTION_EVENT_V1" },
    "schema_version": { "type": "integer", "const": 1 },
    "produced_utc": { "type": "string" },
    "day_utc": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "submission_id": { "type": "string", "minLength": 8 },
    "reason_code": { "type": "string" },
    "reason_detail": { "type": "string" },
    "authoritative": { "type": "boolean", "const": true },
    "canonical_json_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
