{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "execution_evidence_quarantine_tombstone.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id",
    "schema_version",
    "produced_utc",
    "day_utc",
    "submission_id",
    "quarantine_reason",
    "original_hash",
    "timestamp",
    "authoritative"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "C2_EXECUTION_EVIDENCE_QUARANTINE_TOMBSTONE_V1" },
    "schema_version": { "type": "integer", "const": 1 },
    "produced_utc": { "type": "string" },
    "day_utc": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "submission_id": { "type": "string", "minLength": 8 },
    "quarantine_reason": {
      "type": "string",
      "enum": ["SCHEMA_FAILURE", "PARSE_FAILURE", "INTEGRITY_FAILURE"]
    },
    "original_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "timestamp": { "type": "string" },
    "authoritative": { "type": "boolean", "const": false },
    "details": { "type": "object" }
  }
}
